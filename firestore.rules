rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getCommunityData(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data;
    }
    
    function isCommunityMember(communityId) {
      return isAuthenticated() && 
             request.auth.uid in getCommunityData(communityId).members;
    }
    
    function isCommunityAdmin(communityId) {
      return isAuthenticated() && 
             request.auth.uid in getCommunityData(communityId).admins;
    }
    
    function isCommunityCreator(communityId) {
      return isAuthenticated() && 
             getCommunityData(communityId).creatorId == request.auth.uid;
    }
    
    // Users collection - stores user profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);
    }
    
    // UserPosts collection - stores user posts
    match /userPosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // PostComments collection - stores comments on posts
    match /postComments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // PostLikes collection - stores likes on posts
    match /postLikes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Notifications collection - stores user notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Direct message channels between two users
    match /directMessageChannels/{channelId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;

      allow create: if isAuthenticated() &&
                    request.resource.data.participants is list &&
                    request.resource.data.participants.size() == 2 &&
                    request.auth.uid in request.resource.data.participants;

      allow update: if isAuthenticated() &&
                    request.auth.uid in resource.data.participants &&
                    request.resource.data.participants == resource.data.participants;

      allow delete: if false;

      // Direct message content for each channel
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/directMessageChannels/$(channelId)).data.participants;
        allow create: if isAuthenticated() &&
                      request.auth.uid in get(/databases/$(database)/documents/directMessageChannels/$(channelId)).data.participants &&
                      request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() &&
                      request.auth.uid in get(/databases/$(database)/documents/directMessageChannels/$(channelId)).data.participants &&
                      resource.data.senderId == request.auth.uid;
        allow delete: if false;
      }
    }
    
    // Communities collection - stores community information
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       request.resource.data.creatorId == request.auth.uid &&
                       request.auth.uid in request.resource.data.members &&
                       request.auth.uid in request.resource.data.admins;
      allow update: if isAuthenticated() && (
        // Allow creator/admin to update most fields
        (isCommunityAdmin(communityId) || isCommunityCreator(communityId)) ||
        // Allow any authenticated user to join/leave (update members array only)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberCount']))
      );
      allow delete: if isCommunityAdmin(communityId) || isCommunityCreator(communityId);
      
      // Community Members subcollection
      match /communityMembers/{memberId} {
        allow read: if isCommunityMember(communityId) || isCommunityAdmin(communityId) || isCommunityCreator(communityId);
        allow create: if isAuthenticated();
        allow delete: if isCommunityAdmin(communityId) || isCommunityCreator(communityId) || isOwner(memberId);
      }
      
      // Community Posts subcollection
      match /posts/{postId} {
        allow read: if isCommunityMember(communityId);
        allow create: if isCommunityMember(communityId) && 
                         request.resource.data.userId == request.auth.uid;
        allow update: if isCommunityMember(communityId) && 
                         (resource.data.userId == request.auth.uid || 
                          isCommunityAdmin(communityId));
        allow delete: if isCommunityMember(communityId) && 
                         (resource.data.userId == request.auth.uid || 
                          isCommunityAdmin(communityId) ||
                          isCommunityCreator(communityId));
        
        // Comments subcollection under posts
        match /comments/{commentId} {
          allow read: if isCommunityMember(communityId);
          allow create: if isCommunityMember(communityId) && 
                           request.resource.data.userId == request.auth.uid;
          allow update: if false; // Comments should not be updated
          allow delete: if isAuthenticated() && 
                           (resource.data.userId == request.auth.uid || 
                            isCommunityAdmin(communityId) ||
                            isCommunityCreator(communityId));
        }
      }
      
      // Community Media subcollection
      match /media/{mediaId} {
        allow read: if isCommunityMember(communityId);
        allow create: if isCommunityMember(communityId) && 
                         request.resource.data.uploadedBy == request.auth.uid;
        allow delete: if isCommunityMember(communityId) && 
                         (resource.data.uploadedBy == request.auth.uid || 
                          isCommunityAdmin(communityId) ||
                          isCommunityCreator(communityId));
      }
      
      // Community Chat subcollection
      match /chat/{messageId} {
        allow read: if isCommunityMember(communityId);
        allow create: if isCommunityMember(communityId) && 
                         request.resource.data.userId == request.auth.uid;
        allow update: if false; // Chat messages should not be updated
        allow delete: if isCommunityAdmin(communityId) || isCommunityCreator(communityId);
      }
    }
  }
}
