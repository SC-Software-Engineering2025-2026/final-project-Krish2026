{
  "name": "sfera",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sfera - A modern social media platform for digital communities",
  "scripts": {
    "start": "concurrently \"npm run emulators\" \"npm run dev\"",
    "start:prod": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "emulators": "firebase emulators:start --import=./firebase-data --export-on-exit",
    "emulators:ui": "firebase emulators:start --import=./firebase-data --export-on-exit",
    "kill": "lsof -ti:8080,9099,9199,4000,4400,3000,3001 2>/dev/null | xargs kill -9 2>/dev/null; sleep 2 && echo 'Ports cleared'"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.1",
    "date-fns": "^3.3.1",
    "firebase": "^12.9.0",
    "i18next": "^25.10.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^16.6.6",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "firebase-tools": "^13.0.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "vitest": "^4.1.1"
  }
}
