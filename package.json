{
  "name": "sfera",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sfera - A modern social media platform for digital communities",
  "scripts": {
    "start": "concurrently \"npm run emulators\" \"npm run dev\"",
    "start:prod": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "emulators": "firebase emulators:start --import=./firebase-data --export-on-exit",
    "emulators:ui": "firebase emulators:start --import=./firebase-data --export-on-exit"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.1",
    "date-fns": "^3.3.1",
    "firebase": "^12.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "firebase-tools": "^13.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
